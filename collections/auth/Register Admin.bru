meta {
  name: Register Admin
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/identity/register
  body: json
  auth: none
}

body:json {
  {
    "userName": "admin",
    "email": "admin@example.com",
    "password": "Admin123!",
    "firstName": "Admin",
    "lastName": "User"
  }
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{authToken}}
}

vars:pre-request {
  baseUrl: http://localhost:7000
  authToken: your-jwt-token-here
}
