meta {
  name: Seed More Users
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/data/users
  body: json
  auth: bearer
}

body:json {
  {
    "username": "jane_smith",
    "email": "jane.smith@example.com",
    "firstName": "Jane",
    "lastName": "Smith",
    "createdAt": "2024-01-16T14:20:00Z"
  }
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{authToken}}
}

auth:bearer {
  token: {{authToken}}
}

vars:pre-request {
  baseUrl: http://localhost:7000
}
